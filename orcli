def execute_code_blocks(full_text, cfg):
    """Finds executable code blocks and executes them with minimal prompting."""
    blocks = re.findall(r'```(\w*)\n?([\s\S]*?)```', full_text)
    if not blocks: return

    executable_blocks = []
    for lang, code in blocks:
        lang_clean = lang.lower().strip()
        if lang_clean in ("bash", "sh", "zsh", "python", "py"):
            executable_blocks.append((lang_clean, code))

    if not executable_blocks: return

    mode = cfg.get("mode", "safe") # safe or auto

    if mode == "auto":
        print(col("\n    ⚙️  Running...", T["accent3"]))
    else:
        print()
        prompt = col(f"    ▶ Run? [Y/n] ", T["accent3"], BOLD)
        ch = input(prompt).strip().lower()
        if ch in ('n', 'no'):
            return

    for idx, (lang, code) in enumerate(executable_blocks, 1):
        print(col(f"\n    🚀 block #{idx} ({lang})", T["accent3"]))
        print(col("    " + "─"*(tw()-8), T["muted"]))

        if lang in ("bash", "sh", "zsh"):
            tmp_pwd = "/tmp/orcli-pwd"
            wrapper_script = code + f"\npwd > {tmp_pwd}"

            try:
                subprocess.run(wrapper_script, shell=True, text=True)
                if os.path.exists(tmp_pwd):
                    with open(tmp_pwd) as f:
                        new_path = f.read().strip()
                    if os.path.exists(new_path) and new_path != os.getcwd():
                        os.chdir(new_path)
                        print(col(f"    📂 {new_path}", T["accent2"]))
                    try: os.remove(tmp_pwd)
                    except: pass
            except Exception as ex:
                print(col(f"    ❌ {ex}", T["error"]))

        elif lang in ("python", "py"):
            try:
                subprocess.run([sys.executable, "-c", code])
            except Exception as ex:
                print(col(f"    ❌ {ex}", T["error"]))

        print(col("    " + "─"*(tw()-8), T["muted"]))
        print(col("    ✓ done", T["accent3"]))

