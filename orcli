                else:
                    print(col("  ⚠ Use: /mode safe  or  /mode auto", T["accent6"]))
            continue


        last_user = user_input

        # Smart context: auto-inject directory listing for coding questions
        actual_content = user_input
        if not low.startswith("/file") and is_coding_question(user_input):
            dir_ctx = get_dir_context()
            if dir_ctx:
                actual_content = user_input + f"\n\n[Current directory: {os.getcwd()}]\n[Files here:]\n{dir_ctx}"

