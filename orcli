                print(col("  ⚠ Nothing to retry", T["accent6"])); continue
            if messages and messages[-1]["role"] == "assistant": messages.pop()
            if messages and messages[-1]["role"] == "user":      messages.pop()
            user_input = last_user
            print(col(f"  🔁 Retrying...", T["accent6"]))
        elif low == "/model":
