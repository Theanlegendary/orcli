def _req(url, data=None, method="GET", timeout=30):
    hdrs = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
        "HTTP-Referer": "https://orcli.local",
        "X-Title": f"orcli/{VERSION}",
    }
    body = json.dumps(data).encode() if data else None
    req  = urllib.request.Request(url, data=body, headers=hdrs, method=method)
    try:
        return urllib.request.urlopen(req, timeout=timeout), None
    except urllib.error.HTTPError as e:
        return None, {"code": e.code, "body": e.read().decode("utf-8","replace")}
    except Exception as ex:
        return None, {"code": 0, "body": str(ex)}

def get_models():
    sp = Spinner("Fetching free models"); sp.start()
    resp, err = _req(f"{BASE_URL}/models", timeout=15)
    sp.stop()
    if not resp:
        print(col(f"  ❌  {err}", T["error"])); return []
    data = json.loads(resp.read().decode("utf-8","replace")).get("data", [])
    free = []
    for m in data:
        p = m.get("pricing", {})
        try:
            if float(p.get("prompt","1"))==0 and float(p.get("completion","1"))==0:
                free.append(m)
        except: pass
    def rank(m):
        mid = m["id"]
        for i, p in enumerate(CODING_PRIORITY):
            if p in mid: return (0, i, m.get("name",""))
        return (1, 999, m.get("name",""))
    return sorted(free, key=rank)

def get_credits():
    resp, _ = _req(f"{BASE_URL}/auth/key", timeout=10)
    if not resp: return None
    d = json.loads(resp.read().decode("utf-8","replace")).get("data", {})
    lim, used = d.get("limit"), d.get("usage", 0)
    if lim:
        rem = max(0, lim - used)
        return {"limit": lim, "usage": used, "remaining": rem, "pct": (rem/lim)*100}
    return {"limit": None, "usage": used, "remaining": None, "pct": None}

def stream_response(model_id, messages):
    payload = {
        "model": model_id,
        "messages": [{"role":"system","content":SYSTEM_PROMPT}] + messages,
        "stream": True,
    }
    resp, err = _req(f"{BASE_URL}/chat/completions", data=payload, method="POST", timeout=90)
    if not resp:
        yield "error", err; return
    tokens = 0
    try:
        for raw in resp:
            line = raw.decode("utf-8","replace").strip()
            if not line.startswith("data: "): continue
            ds = line[6:]
            if ds == "[DONE]": break
            try: obj = json.loads(ds)
            except: continue
            if obj.get("usage"):
                tokens = obj["usage"].get("total_tokens", tokens)
            choices = obj.get("choices", [])
            if not choices: continue
            chunk = choices[0].get("delta", {}).get("content", "")
            if chunk: yield "chunk", chunk
    except Exception as ex:
        yield "error", {"code": 0, "body": str(ex)}; return
    yield "done", tokens

def is_rate_err(err):
    if not err: return False
    b = err.get("body","").lower()
    return err.get("code",0) in (429,503,402) or any(
        k in b for k in ["rate limit","quota","limit exceeded","exhausted",
                          "overloaded","too many","credits","context length"])

