def _kw(pat): return (pat, "keyword")
def _str(pat): return (pat, "string")
def _cmt(pat): return (pat, "comment")
def _num(pat): return (pat, "number")
def _fn2(pat): return (pat, "funcname")
def _cls(pat): return (pat, "classname")
def _dec(pat): return (pat, "decorator")

def _apply_type(tok_type, full_match, groups):
    if tok_type == "keyword":    return col(full_match, T["accent1"], BOLD)
    if tok_type == "string":     return col(full_match, T["accent4"])
    if tok_type == "string_val": return ": " + col(groups[0], T["accent4"])
    if tok_type == "comment":    return col(full_match, T["muted"], ITALIC)
    if tok_type == "number":     return col(full_match, T["accent5"])
    if tok_type == "constant":   return col(full_match, T["accent2"])
    if tok_type == "variable":   return col(full_match, T["accent6"])
    if tok_type == "classname":  return col(full_match, T["accent2"], BOLD)
    if tok_type == "decorator":  return col(full_match, T["accent2"], ITALIC)
    if tok_type == "def_fn":
        kw = full_match.split()[0]
        nm = groups[0]
        return col(kw, T["accent1"], BOLD) + " " + col(nm, T["accent3"], BOLD)
    if tok_type == "def_cls":
        kw = full_match.split()[0]
        nm = groups[0]
        return col(kw, T["accent1"], BOLD) + " " + col(nm, T["accent2"], BOLD)
    if tok_type == "def_cls2":
        parts = full_match.split()
        kw = parts[0]
        nm = groups[1] if len(groups) > 1 else groups[0]
        return col(kw, T["accent1"], BOLD) + " " + col(nm, T["accent2"], BOLD)
    return col(full_match, T["text"])

