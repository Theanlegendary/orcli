        if not messages or messages[-1].get("content") != user_input:
            messages.append({"role": "user", "content": actual_content})
        msg_count += 1

        # Echo user message as sent bubble with timestamp
        ts_sent = datetime.datetime.now().strftime("%H:%M")
        echo_text = user_input[:120] + ("…" if len(user_input) > 120 else "")
        if not low.startswith("/file"):
            print(col(f"  You", T["accent1"], BOLD) + col(f"  {ts_sent}", T["muted"]))
            for eline in echo_text.split("\n"):
                print(col(f"    {eline}", T["dim_text"]))
        print(col(f"  ✓✓ seen", T["muted"], ITALIC))

        replied = False; tried = set()
        while not replied:
            if len(exhausted) >= len(models): break
            if cur in exhausted or cur in tried:
                found = False
                for i in range(len(models)):
                    if i not in exhausted and i not in tried:
                        cur = i; found = True; break
                if not found: break

            tried.add(cur)
            model = models[cur]
            mname = model["name"]

            # AI bubble header — clean and minimal
            print()
            short_name = mname.split("/")[-1] if "/" in mname else mname
            print(col(f"  {short_name}", T["accent3"], BOLD))

            full_text   = ""; in_think = False; think_open = False
            text_buf    = ""; got_error = None; tokens = 0

            sp = Spinner("AI is typing")
            sp.start(); first_chunk = True

            # Loop detector
            recent_lines  = []; loop_detected = False
            LOOP_WIN, LOOP_THR = 6, 3

            def _check_loop(ln):
                nonlocal loop_detected
                s = re.sub(r'\033\[[^m]*m', '', ln).strip()
                if not s: return False
                recent_lines.append(s)
                if len(recent_lines) > LOOP_WIN*2: recent_lines.pop(0)
                if len(recent_lines) >= LOOP_WIN:
                    from collections import Counter
                    top = Counter(recent_lines[-LOOP_WIN:]).most_common(1)[0]
                    if top[1] >= LOOP_THR:
                        loop_detected = True; return True
                return False

            for event, data in stream_response(model["id"], messages):
                if loop_detected: break
                if first_chunk and event in ("chunk","done","error"):
                    sp.stop(); first_chunk = False

                if event == "chunk":
                    full_text += data; text_buf += data
                    while True:
                        if not in_think:
                            ts = text_buf.find("<think>")
                            if ts != -1:
                                pre = text_buf[:ts]
                                if pre.strip():
                                    sys.stdout.write(render_md(pre)); sys.stdout.flush()
                                text_buf = text_buf[ts+7:]
                                in_think = True; think_open = True; think_header()
                            else:
                                if "\n" in text_buf:
                                    parts = text_buf.split("\n")
                                    for ln in parts[:-1]:
                                        sys.stdout.write(render_md(ln) + "\n")
                                        sys.stdout.flush()
                                        if _check_loop(ln): break
                                    text_buf = parts[-1]
                                break
                        else:
                            te = text_buf.find("</think>")
                            if te != -1:
                                for ln in text_buf[:te].split("\n"): think_line(ln)
                                think_footer(); think_open = False
                                text_buf = text_buf[te+8:]; in_think = False
                            else:
                                if "\n" in text_buf:
                                    parts = text_buf.split("\n")
                                    for ln in parts[:-1]: think_line(ln)
                                    text_buf = parts[-1]
                                break

                elif event == "done":
                    if first_chunk: sp.stop(); first_chunk = False
                    tokens = data
                    if think_open: think_footer()
                    if text_buf.strip():
                        sys.stdout.write(render_md(text_buf) + "\n"); sys.stdout.flush()
                    replied = True

                elif event == "error":
                    if first_chunk: sp.stop(); first_chunk = False
                    got_error = data; break

            if loop_detected and not replied:
                if first_chunk: sp.stop()
                print(col(f"\n  🔁 Loop detected, switching...", T["accent6"]))
                exhausted.add(cur)
                if messages and messages[-1]["role"] == "assistant": messages.pop()
                continue

            if replied:
                session_tok += tokens
                # Timestamp + delivered indicator like Messenger
                ts_str = datetime.datetime.now().strftime("%H:%M")
                tok_label = f"{tokens}" if tokens else ""
                print(col(f"\n  {ts_str}  ✓", T["muted"]) + (col(f"  {tok_label} tok", T["muted"]) if tok_label else ""))
                print(col("  " + "─"*(tw()-4), T["muted"]))
                messages.append({"role": "assistant", "content": full_text})

                # Auto-save conversation after each exchange
                save_conversation(messages, mname)

                # TRIGGER COMMAND EXECUTION
                execute_code_blocks(full_text, cfg)

            elif got_error:
                if is_rate_err(got_error):
                    print(col(f"\n  ⚡ Rate limited, switching...", T["accent6"]))
                    exhausted.add(cur)
                else:
                    body = got_error.get("body","?")[:160]
                    print(col(f"\n  ❌  Error ({got_error.get('code','?')}): {body}", T["error"]))
                    messages.pop(); break

        if not replied and len(exhausted) >= len(models):
            save_conversation(messages, "exhausted")
            print(col("\n  All models exhausted 🌙", T["error"]))
            sys.exit(0)

# ──────────────────────────────────────────────────────
#  MAIN
# ──────────────────────────────────────────────────────
def main():
    global T, API_KEY
    parser = argparse.ArgumentParser(prog="orcli", add_help=False)
    parser.add_argument("--theme", default=None)
    parser.add_argument("--list-themes", action="store_true")
    parser.add_argument("--auth", action="store_true", help="Setup API key")
    args, _ = parser.parse_known_args()

    cfg = load_config()
    if args.list_themes:
        print("\n  Available themes: " + ", ".join(THEMES.keys()) + "\n"); sys.exit(0)

    theme_name = args.theme or cfg.get("theme", "ark")
    if theme_name not in THEMES: theme_name = "ark"
    T = THEMES[theme_name]

    # Clean Messenger-style startup
    print()
    print(col("  orcli", T["accent1"], BOLD) + col(f"  v{VERSION}", T["muted"]))
    print(col("  " + "─"*(tw()-4), T["muted"]))

    # Handle --auth flag
    if args.auth:
        setup_auth()
        sys.exit(0)

    # Try loading key from config if env var is empty
    if not API_KEY:
        cfg_key = cfg.get("api_key", "")
        if cfg_key:
            API_KEY = cfg_key
            os.environ["OPENROUTER_API_KEY"] = cfg_key

    if not API_KEY:
        print(col("  No API key found", T["accent6"]))
        print(col("  Let's set one up:", T["muted"]))
        if setup_auth():
            API_KEY = os.environ.get("OPENROUTER_API_KEY", "")
        if not API_KEY:
            print(col("  Run: orcli --auth\n", T["muted"]))
            sys.exit(1)

    print_credits()
    models = get_models()
    if not models:
        print(col("  No free models found.", T["error"])); sys.exit(1)

    # Just show the active model, not the full list
    print(col(f"  {len(models)} models", T["accent3"]) + col("  ·  /model to browse", T["muted"]))
    print(col(f"  → {models[0]['name']}", T["accent3"], BOLD))
    print()

    # Check for direct arguments or piped input
    direct_query = ""
    if len(sys.argv) > 1 and not sys.argv[1].startswith("-"):
        direct_query = " ".join(sys.argv[1:])
    elif not sys.stdin.isatty():
        direct_query = sys.stdin.read().strip()

    if direct_query:
        # Run a single query non-interactively
        model = models[0]
        short_name = model['name'].split('/')[-1] if '/' in model['name'] else model['name']
        print(col(f"  {short_name}", T["accent3"], BOLD))
        
        full_text = ""
        in_think = False
        text_buf = ""
        think_open = False
        
        for event, data in stream_response(model["id"], [{"role": "user", "content": direct_query}]):
            if event == "chunk":
                full_text += data
                text_buf += data
                while True:
                    if not in_think:
                        ts = text_buf.find("<think>")
                        if ts != -1:
                            pre = text_buf[:ts]
                            if pre.strip():
                                sys.stdout.write(render_md(pre))
                                sys.stdout.flush()
                            text_buf = text_buf[ts+7:]
                            in_think = True
                            think_open = True
                            think_header()
                        else:
                            if "\n" in text_buf:
                                parts = text_buf.split("\n")
                                for ln in parts[:-1]:
                                    sys.stdout.write(render_md(ln) + "\n")
                                    sys.stdout.flush()
                                text_buf = parts[-1]
                            break
                    else:
                        te = text_buf.find("</think>")
                        if te != -1:
                            for ln in text_buf[:te].split("\n"):
                                think_line(ln)
                            think_footer()
                            think_open = False
                            text_buf = text_buf[te+8:]
                            in_think = False
                        else:
                            if "\n" in text_buf:
                                parts = text_buf.split("\n")
                                for ln in parts[:-1]:
                                    think_line(ln)
                                text_buf = parts[-1]
                            break
            elif event == "done":
                if think_open:
                    think_footer()
                if text_buf.strip():
                    sys.stdout.write(render_md(text_buf) + "\n")
                    sys.stdout.flush()
                break
            elif event == "error":
                print(col(f"\n❌ Error: {data.get('body', 'unknown')}", T["error"]))
                sys.exit(1)
        
        print(col(f"\n  {datetime.datetime.now():%H:%M}  ✓", T["muted"]))
        execute_code_blocks(full_text, cfg)
        sys.exit(0)

    try:
        chat(models, theme_name, cfg)
    except KeyboardInterrupt:
        print(col("\n\n  👋 Bye!\n", T["accent3"]))
        show_cursor()

if __name__ == "__main__":
    main()
