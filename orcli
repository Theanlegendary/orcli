class Spinner:
    """Messenger-style 'typing' indicator with bouncing dots."""
    DOT_FRAMES = ["·  ", "·· ", "···", " ··", "  ·", "   "]
    def __init__(self, msg="AI is typing"):
        self.msg = msg
        self._stop = threading.Event()
        self._t = threading.Thread(target=self._spin, daemon=True)
    def _spin(self):
        i = 0; hide_cursor()
        while not self._stop.is_set():
            dots = self.DOT_FRAMES[i % len(self.DOT_FRAMES)]
            indicator = col(f"  💬 {self.msg} ", T["muted"], ITALIC) + col(dots, T["accent1"], BOLD)
            sys.stdout.write(f"\r{indicator}"); sys.stdout.flush()
            time.sleep(0.15); i += 1
    def start(self): self._t.start()
    def stop(self):
        self._stop.set(); self._t.join(); clear_line(); show_cursor()

