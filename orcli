            messages.append({"role": "user", "content": file_msg})
            user_input = file_msg
            # Fall through to AI response
        elif low == "/save":
            path = save_conversation(messages, models[cur]["name"] if models else "")
            if path:
                print(col(f"  ✓ Saved → {os.path.basename(path)}", T["accent3"]))
            else:
                print(col("  Nothing to save", T["muted"]))
            continue
        elif low == "/retry":
