def highlight(code, lang):
    rules = LANG_RULES.get(lang.lower(), [])
    result = code
    for pat, tok_type in rules:
        try:
            def replacer(m, t=tok_type): return _apply_type(t, m.group(0), m.groups())
            result = re.sub(pat, replacer, result, flags=re.MULTILINE)
        except: pass
    return result

