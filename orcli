    print(col("  " + "─"*(tw()-4), T["muted"]))

    while True:
        if cur in exhausted:
            for i in range(len(models)):
                if i not in exhausted: cur = i; break

        if len(exhausted) >= len(models):
            print(col("\n  All models exhausted. Try again later 🌙", T["error"]))
            sys.exit(0)

        # Prompt (Messenger Style: clean message box)
        print()
        try:
            cwd_short = os.path.basename(os.getcwd()) or "/"
            lines = []; first = True
            while True:
                if first:
                    pfx = col(f"  {cwd_short}", T["muted"]) + col(" › ", T["accent1"], BOLD)
                else:
                    pfx = col("    … ", T["muted"])
                first = False
                part = input(pfx).rstrip()
                if part.endswith("\\"):
                    lines.append(part[:-1])
                else:
                    lines.append(part); break
            user_input = "\n".join(lines).strip()
        except (KeyboardInterrupt, EOFError):
            print(col("\n\n👋 Goodbye!\n", T["accent3"], BOLD))
            show_cursor(); sys.exit(0)

        if not user_input: continue
        low = user_input.lower().strip()

        # Commands
        if low in ("/exit", "/quit"):
            save_conversation(messages, models[cur]["name"] if models else "")
            print(col("\n  👋 Bye!\n", T["accent3"])); show_cursor(); sys.exit(0)
        elif low == "/help":
            print_help(theme_name); continue
        elif low == "/clear":
            save_conversation(messages, models[cur]["name"] if models else "")
            messages = []; last_user = ""; msg_count = 0
            print(col("  ✓ Cleared (saved)", T["accent3"])); continue
        elif low == "/credits":
            print_credits(); continue
        elif low == "/auth":
            setup_auth(); continue
        elif low == "/history":
            if not messages:
                print(col("  (no history yet)", T["muted"]))
            else:
                for msg in messages:
                    who  = col("  You: ", T["accent1"], BOLD) if msg["role"]=="user" else col("  AI:  ", T["accent3"], BOLD)
                    snip = msg["content"][:200].replace("\n"," ")
                    print(who + col(snip + ("…" if len(msg["content"])>200 else ""), T["dim_text"]))
            continue
        elif low == "/resume":
            convos = list_conversations(10)
            if not convos:
                print(col("  No saved conversations", T["muted"])); continue
            print()
            print(col("  Recent chats", T["accent1"], BOLD))
            print(col("  " + "─"*(tw()-4), T["muted"]))
            for i, c in enumerate(convos, 1):
                ts_display = c["saved"][:8] if c["saved"] else "?"
                print(col(f"  {i:>2}.", T["muted"]) + col(f" {c['preview'][:50]}", T["text"]) + col(f"  ({c['count']} msgs)", T["muted"]))
            print()
            try:
                ch = input(col("  # ", T["accent1"], BOLD)).strip()
