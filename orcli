# ──────────────────────────────────────────────────────
def render_code_block(lang, code):
    W = tw()
    label = lang.upper() if lang else "CODE"
    # Clean pill-style label
    hdr = col(f" {label} ", T["bg_label"], T["label_fg"], BOLD)
    rows = [f"    {hdr}"]
    for raw in code.rstrip().split("\n"):
        hl   = highlight(raw, lang)
        bg   = T["bg_code"]
        hl_b = bg + reapply_bg(hl, bg)
        pad  = " " * max(0, W - 8 - dw(raw))
        rows.append(col("    ", bg) + hl_b + pad + RST)
    return "\n" + "\n".join(rows) + "\n"

# ──────────────────────────────────────────────────────
#  MARKDOWN RENDER (Messenger Style)
# ──────────────────────────────────────────────────────
def render_md(text):
    # 1. Protect code blocks
    def sub_code(m):
        return render_code_block((m.group(1) or "").strip(), m.group(2))
    text = re.sub(r'```(\w*)\n?([\s\S]*?)```', sub_code, text)

    # 2. Inline code
    text = re.sub(r'`([^`\n]+)`',
        lambda m: T["bg_code"] + T["accent2"] + " " + m.group(1) + " " + RST, text)

    # 3. Bold + italic
    text = re.sub(r'\*\*\*(.+?)\*\*\*', lambda m: col(m.group(1), BOLD, ITALIC, T["text"]), text)
    text = re.sub(r'\*\*(.+?)\*\*',     lambda m: col(m.group(1), BOLD, T["text"]),          text)
    text = re.sub(r'\*(.+?)\*',         lambda m: col(m.group(1), ITALIC, T["dim_text"]),    text)

    # 4. Headers (Clean Messenger Style)
    text = re.sub(r'^# (.+)$',    lambda m: "\n" + col("💬 " + m.group(1).upper(), T["accent1"], BOLD), text, flags=re.MULTILINE)
    text = re.sub(r'^## (.+)$',   lambda m: "\n" + col("🔹 " + m.group(1), T["accent2"], BOLD), text, flags=re.MULTILINE)
    text = re.sub(r'^### (.+)$',  lambda m: col("▪ " + m.group(1), T["accent2"], BOLD), text, flags=re.MULTILINE)

    # 5. Lists
    text = re.sub(r'^      [-*•] (.+)$', lambda m: "      ◦ " + col(m.group(1), T["dim_text"]), text, flags=re.MULTILINE)
    text = re.sub(r'^    [-*•] (.+)$',   lambda m: "    ◦ " + col(m.group(1), T["dim_text"]), text, flags=re.MULTILINE)
    text = re.sub(r'^  [-*•] (.+)$',     lambda m: "  ◦ " + col(m.group(1), T["dim_text"]), text, flags=re.MULTILINE)
    text = re.sub(r'^[-*•] (.+)$',       lambda m: "• " + col(m.group(1), T["text"]), text, flags=re.MULTILINE)

    # 6. Numbered list
    text = re.sub(r'^(\d+)\. (.+)$',
        lambda m: col(f"{m.group(1)}.", T["accent1"], BOLD) + " " + col(m.group(2), T["text"]),
        text, flags=re.MULTILINE)

    # 7. Blockquote
    text = re.sub(r'^> (.+)$',
        lambda m: col("│ ", T["accent1"], BOLD) + col(m.group(1), T["dim_text"], ITALIC),
        text, flags=re.MULTILINE)

    # 8. Horizontal rule
    text = re.sub(r'^---+$', col("  " + "─"*(tw()-4), T["muted"]), text, flags=re.MULTILINE)

    out = []
    for ln in text.split("\n"):
        plain = re.sub(r'\033\[[^m]*m', '', ln)
        if plain.strip() and not ln.startswith("    ") and not ln.startswith("  ") and not ln.startswith("•") and not ln.startswith("💬") and not ln.startswith("🔹") and not ln.startswith("▪") and not ln.startswith("│"):
            ln = "    " + col(plain, T["text"])
        out.append(ln)
    return "\n".join(out)

