def _ensure_history():
    os.makedirs(HISTORY_DIR, exist_ok=True)

def save_conversation(messages, model_name=""):
    """Auto-save conversation to ~/.orcli-history/"""
    if not messages: return None
    _ensure_history()
    ts = datetime.datetime.now().strftime("%Y%m%d-%H%M%S")
    # Generate a title from first user message
    title = "chat"
    for m in messages:
        if m["role"] == "user":
            title = re.sub(r'[^\w\s-]', '', m["content"][:40]).strip().replace(" ", "-").lower()
            break
    fname = f"{ts}_{title}.json"
    path = os.path.join(HISTORY_DIR, fname)
    try:
        with open(path, "w") as f:
            json.dump({"model": model_name, "messages": messages, "saved": ts}, f, indent=2)
        return path
    except: return None

def list_conversations(limit=10):
    """List recent saved conversations."""
    _ensure_history()
    files = sorted(
        [f for f in os.listdir(HISTORY_DIR) if f.endswith(".json")],
        reverse=True
    )[:limit]
    convos = []
    for f in files:
        try:
            with open(os.path.join(HISTORY_DIR, f)) as fh:
                data = json.load(fh)
            user_msgs = [m for m in data.get("messages", []) if m["role"] == "user"]
            preview = user_msgs[0]["content"][:60] if user_msgs else "(empty)"
            convos.append({"file": f, "preview": preview, "count": len(data.get("messages", [])), "saved": data.get("saved", "")})
        except: pass
    return convos

def load_conversation(filename):
    """Load a saved conversation."""
    path = os.path.join(HISTORY_DIR, filename)
    try:
        with open(path) as f:
            return json.load(f)
    except: return None

def read_file_content(filepath):
    """Read a file and return its content with language detection."""
    path = os.path.expanduser(filepath.strip())
    if not os.path.exists(path):
        return None, "File not found"
    if os.path.getsize(path) > 100_000:
        return None, "File too large (>100KB)"
    try:
        with open(path, "r", errors="replace") as f:
            content = f.read()
        ext = os.path.splitext(path)[1].lstrip(".")
        lang_map = {"py":"python","js":"javascript","ts":"typescript","rb":"ruby",
                    "go":"go","rs":"rust","sh":"bash","zsh":"bash","json":"json",
                    "yml":"yaml","yaml":"yaml","md":"markdown","css":"css",
                    "html":"html","sql":"sql","txt":"text"}
        lang = lang_map.get(ext, ext or "text")
        return content, lang
    except Exception as ex:
        return None, str(ex)

def get_dir_context():
    """Get a brief listing of current directory for smart context."""
    try:
        entries = os.listdir(".")
        files = sorted([e for e in entries if os.path.isfile(e)])[:20]
        dirs = sorted([e + "/" for e in entries if os.path.isdir(e) and not e.startswith(".")])[:10]
        listing = dirs + files
        if not listing: return ""
        return "\n".join(listing[:30])
    except: return ""

def setup_auth(silent=False):
    """Interactive API key setup. Writes to shell rc file."""
    global API_KEY
    if not silent:
        print()
        print(col("  🔑 Auth Setup", T["accent1"], BOLD))
        print(col("  " + "─"*(tw()-4), T["muted"]))
        print(col("  1. Go to  https://openrouter.ai/keys", T["text"]))
        print(col("  2. Create a free key (starts with sk-or-)", T["text"]))
        print(col("  3. Paste it below", T["text"]))
        print()
    try:
        key = input(col("  Key: ", T["accent2"], BOLD)).strip()
    except (KeyboardInterrupt, EOFError):
        print(); return False
    if not key:
        print(col("  ✗ No key entered", T["error"])); return False
    if not key.startswith("sk-or-"):
        print(col("  ⚠ Key should start with sk-or-", T["accent6"]))
        try:
            confirm = input(col("  Save anyway? [y/N] ", T["muted"])).strip().lower()
            if confirm not in ("y", "yes"): return False
        except (KeyboardInterrupt, EOFError):
            print(); return False

    # Validate by testing the key
    print(col("  Validating...", T["muted"], ITALIC))
    test_hdrs = {"Authorization": f"Bearer {key}", "Content-Type": "application/json"}
    test_req = urllib.request.Request(f"{BASE_URL}/auth/key", headers=test_hdrs)
    try:
        resp = urllib.request.urlopen(test_req, timeout=10)
        data = json.loads(resp.read().decode()).get("data", {})
        print(col("  ✓ Key is valid", T["accent3"], BOLD))
        if data.get("limit"):
            rem = max(0, data["limit"] - data.get("usage", 0))
            print(col(f"  Balance: ${rem:.4f}", T["accent3"]))
    except:
        print(col("  ⚠ Could not validate (saving anyway)", T["accent6"]))

    # Write to shell rc file
    export_line = f'export OPENROUTER_API_KEY="{key}"'
    rc = RC_FILE
    try:
        # Remove old key line if present
        if os.path.exists(rc):
            with open(rc) as f:
                existing = f.readlines()
            filtered = [l for l in existing if "OPENROUTER_API_KEY" not in l]
            with open(rc, "w") as f:
                f.writelines(filtered)
        # Append new key
        with open(rc, "a") as f:
            f.write(f"\n# orcli — OpenRouter API key\n{export_line}\n")
        print(col(f"  ✓ Saved to {os.path.basename(rc)}", T["accent3"]))
    except Exception as ex:
        print(col(f"  ✗ Could not write {rc}: {ex}", T["error"]))
        print(col(f"  Add manually: {export_line}", T["accent2"]))
        return False

    # Also save to config for immediate use
    cfg = load_config()
    cfg["api_key"] = key
    save_config(cfg)

    # Set in current process
    os.environ["OPENROUTER_API_KEY"] = key
    API_KEY = key
    print(col("  ✓ Ready! Restart orcli or run: source " + os.path.basename(rc), T["accent3"]))
    print()
    return True

def is_coding_question(text):
    """Detect if user's message is likely about code/files."""
    coding_words = ["code", "file", "error", "bug", "fix", "run", "install", "build",
                    "import", "function", "class", "script", "command", "terminal",
                    "npm", "pip", "git", "docker", "make", "compile", "debug",
                    "create", "write", "edit", "modify", "update", "add", "remove",
                    "package", "dependency", "module", "project", "app", "server"]
    low = text.lower()
    return any(w in low for w in coding_words)

